    }

    package "Emulated (9 backends)" as ef_emu #FFECB3 {
        component "emulated_event_flags.inl" as ef_inl #FFE082
        note bottom of ef_inl
          **Mutex + per-waiter semaphore array**
          ──────────────────────────────────────
          • OSAL mutex guards bits + waiter array
          • Each waiter gets a binary semaphore slot
          • set() : OR bits, give all waiter semas
          • set_isr() : volatile OR + give_isr
          • wait : claim slot → sem_take → re-check
          • Static pool, zero heap allocation
        end note

        [POSIX] as ef_po
        [Linux] as ef_li
        [Bare-metal] as ef_bm
