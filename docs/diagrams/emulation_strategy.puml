' ============================================================================
' Mailbox
' ============================================================================
package "Mailbox (osal::mailbox<T>)" as mb_pkg #F1F8E9 {

        package "Header-only adapter (all 17 backends)" as mb_all #DCEDC8 {
                component "mailbox.hpp" as mb_hdr #AED581
                note bottom of mb_hdr
                    **queue<T,1> wrapper**
                    ─────────────────────
                    • No new backend ABI
                    • Single-slot typed handoff
                    • Inherits queue timed/ISR semantics
                    • Queue support implies mailbox support
                end note

                [All backends\nvia osal::queue<T,1>] as mb_backends
                [ChibiOS\nqueue path already uses\nnative mailbox_t] as mb_ch
        }

        mb_backends ..> mb_hdr : uses
        mb_ch ..> mb_hdr : native mailbox via queue
}

