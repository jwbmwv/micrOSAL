' Work Queue
' ============================================================================
package "Work Queue (osal::work_queue)" as wq_pkg #E3F2FD {

    package "Native (3 backends)" as wq_native #BBDEFB {
        [Zephyr\nk_work_queue] as wq_zy
        [NuttX\nwork_queue()] as wq_nx
        [VxWorks\njobQueueLib] as wq_vx
    }

    package "Emulated — OSAL primitives (10 backends)" as wq_emu #FFECB3 {
        component "emulated_work_queue.inl" as wq_inl #FFE082
        note bottom of wq_inl
          **Thread + ring buffer**
          ──────────────────────
          • Dedicated worker thread
          • Circular buffer (configurable depth)
          • Mutex + semaphore for sync
          • FIFO execution guarantee
        end note

        [FreeRTOS] as wq_fr
        [ThreadX] as wq_tx
        [PX5] as wq_px
        [QNX] as wq_qx
        [Micrium] as wq_mi
        [ChibiOS] as wq_ch
        [embOS] as wq_em
        [Bare-metal] as wq_bm
        [CMSIS-RTOS] as wq_c1
        [CMSIS-RTOS2] as wq_c2
    }

    package "Emulated — POSIX pthread (4 backends)" as wq_posix #D1C4E9 {
        component "posix_pthread_work_queue.inl" as wq_posix_inl #C5CAE9
        note bottom of wq_posix_inl
          **pthread thread + ring buffer**
          ────────────────────────────────
          • Dedicated pthread worker
          • Circular buffer (configurable depth)
          • pthread_mutex_t + pthread_cond_t
          • CLOCK_MONOTONIC timed waits
          • Drop-in replacement for emu_wq
            on POSIX-family hosts
        end note

        [POSIX] as wq_po
        [Linux] as wq_li
        [RTEMS] as wq_rt
        [INTEGRITY] as wq_in
    }

