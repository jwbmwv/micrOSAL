package "Message Buffer (osal::message_buffer)" as mb_pkg #FCE4EC {

    package "Native (1 backend)" as mb_native #F8BBD0 {
        [FreeRTOS\nxMessageBufferCreate\nxMessageBufferSendFromISR] as mb_fr
    }

    package "Emulated (16 backends)" as mb_emu #FFECB3 {
        component "emulated_message_buffer.inl" as mb_inl #FFE082
        note bottom of mb_inl
          **Length-prefixed SPSC ring**
          ────────────────────────────
          • Wire: [uint16_t len][payload]
          • emu_mb_ prefix avoids anon-NS
            collision with stream_buffer.inl
          • head_ updated once after header
            + payload (no partial-frame reads)
          • Truncation on oversized receive
            (FreeRTOS-compatible semantics)
        end note

        [Zephyr] as mb_zy
        [ThreadX] as mb_tx
