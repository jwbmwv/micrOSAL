' Condvar
' ============================================================================
package "Condition Variable (osal::condvar)" as cv_pkg #E8F5E9 {

    package "Native (9 backends)" as cv_native #C8E6C9 {
        [POSIX\npthread_cond_t] as cv_po
        [Linux\npthread_cond_t\nCLOCK_MONOTONIC] as cv_li
        [QNX\npthread_cond_t\nmonotonic] as cv_qx
        [NuttX\nnxsem-based] as cv_nx
        [RTEMS\npthread_cond_t] as cv_rt
        [INTEGRITY\npthread_cond_t] as cv_in
        [Zephyr\nk_condvar\n(static pool)] as cv_zy
        [ChibiOS\ncondition_variable_t\n(static pool)] as cv_ch
        [VxWorks\ncondVarLib] as cv_vx
    }

    package "Emulated (8 backends)" as cv_emu #FFECB3 {
        component "emulated_condvar.inl" as cv_inl #FFE082
        note bottom of cv_inl
          **Birrell's pattern**
          ────────────────────
          • Guard mutex (osal::mutex)
          • Array of binary semaphores
            (OSAL_CONDVAR_MAX_WAITERS = 8)
          • Pre-allocated at create time
          • notify_one: give first waiter's sem
          • notify_all: give all waiters' sems
        end note

        [FreeRTOS] as cv_fr
        [ThreadX] as cv_tx
        [PX5] as cv_px
        [Micrium] as cv_mi
        [embOS] as cv_em
        [Bare-metal] as cv_bm
        [CMSIS-RTOS] as cv_c1
        [CMSIS-RTOS2] as cv_c2
    }

    cv_fr ..> cv_inl : #include
    cv_tx ..> cv_inl : #include
    cv_px ..> cv_inl : #include
    cv_mi ..> cv_inl : #include
    cv_em ..> cv_inl : #include
    cv_bm ..> cv_inl : #include
