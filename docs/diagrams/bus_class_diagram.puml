@startuml bus_class_diagram
!include _render_profile.puml

title micrOSAL Bus + Signal Layer — Class Diagram

namespace osal {

    class "osal_bus<T,Capacity,BackendTag>" as Bus << (T,#ADD1B2) template >> {
        +valid() : bool
        +try_send(item : T) : bool
        +send(item : T, ticks : tick_t) : bool
        +try_receive(out : T&) : bool
        +receive(out : T&, ticks : tick_t) : bool
    }

    class "osal_bus<T,Capacity,\nbus_backend_generic>" as BusGeneric {
        -handle_ : queue_handle_t
        -storage_ : uint8_t[Capacity*sizeof(T)]
        -valid_ : bool
    }

    class "osal_bus<T,Capacity,\nbus_backend_zephyr>" as BusZephyr {
        -impl_ : osal_bus<T,Capacity,bus_backend_generic>
    }

    Bus <|.. BusGeneric
    Bus <|.. BusZephyr

    class "osal_signal<T,N,M,BackendTag>" as Signal << (T,#ADD1B2) template >> {
        +subscribe(out_id : subscriber_id&) : bool
        +unsubscribe(id : subscriber_id) : bool
        +publish(msg : T) : bool
        +try_receive(id : subscriber_id, out : T&) : bool
        +receive(id : subscriber_id, out : T&, ticks) : bool
        +subscriber_count() : size_t
    }

    class "osal_signal<T,N,M,\nbus_backend_generic>" as SignalGeneric {
        -slots_ : subscriber_slot[N]
        -mutex_ : osal::mutex
        -subscriber_count_ : size_t
    }

    class "osal_signal<T,N,M,\nbus_backend_zephyr>" as SignalZephyr {
    }

    class subscriber_slot {
        +in_use_ : bool
        +queue_ : osal_bus<T,M,bus_backend_generic>
    }

    class "osal_signal_premium<T,N,M,BackendTag>" as SignalPremium {
        +subscribe_observer(fn : observer_fn) : bool
        +unsubscribe_observer(fn : observer_fn) : bool
        +publish(msg : T) : bool
        +publish_zero_copy(ptr : T*) : bool
        +route_to(dest : signal_id, msg : T) : bool
        +observer_count() : size_t
        -observers_ : observer_fn[MaxSubscribers]
        -observer_count_ : size_t
    }

    class "osal_signal_capabilities<BackendTag>" as Caps {
        +native_pubsub : bool
        +native_observers : bool
        +native_routing : bool
        +zero_copy : bool
    }

        Signal <|.. SignalGeneric
        Signal <|.. SignalZephyr
        SignalPremium --|> Signal
        SignalZephyr --|> SignalGeneric
        SignalGeneric *-- subscriber_slot
        subscriber_slot *-- BusGeneric
        BusZephyr *-- BusGeneric : impl_
        SignalPremium ..> Caps : constexpr query

        note right of BusZephyr
            Current Zephyr specialisations
            delegate to the generic runtime.
            A future native Zbus path can
            replace this wrapper.
        end note
}

@enduml
